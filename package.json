{
  "name": "better-auth-invitation-only",
  "version": "1.0.0",
  "description": "Invite-only registration plugin for Better Auth. Gate signups with admin-managed invitation codes, support email + OAuth flows, with full CRUD admin endpoints.",
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "invitation",
    "invite-only",
    "registration",
    "signup",
    "access-control",
    "auth"
  ],
  "author": "Vibe Code <hello@vcode.sh> (https://vcode.sh)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vcode-sh/better-auth-invitation-only.git"
  },
  "bugs": {
    "url": "https://github.com/vcode-sh/better-auth-invitation-only/issues"
  },
  "homepage": "https://github.com/vcode-sh/better-auth-invitation-only#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "npx ultracite check",
    "lint:fix": "npx ultracite fix",
    "prepublishOnly": "npm run type-check && npm run test && npm run build"
  },
  "sideEffects": false,
  "peerDependencies": {
    "better-auth": "^1.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "better-auth": "^1.5.0",
    "better-sqlite3": "^12.6.2",
    "happy-dom": "^20.6.3",
    "lint-staged": "^16.2.7",
    "mongodb": "^7.1.0",
    "mongodb-memory-server": "^11.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "npx ultracite fix"
  }
}
