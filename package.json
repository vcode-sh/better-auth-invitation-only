{
  "name": "better-auth-invitation-only",
  "version": "0.1.0",
  "description": "Invite-only registration plugin for Better Auth. Gate signups with admin-managed invitation codes, support email + OAuth flows, with full CRUD admin endpoints.",
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "invitation",
    "invite-only",
    "registration",
    "signup",
    "access-control",
    "auth"
  ],
  "author": "Vibe Code <hello@vcode.sh> (https://vcode.sh)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vcode-sh/better-auth-invitation-only.git"
  },
  "bugs": {
    "url": "https://github.com/vcode-sh/better-auth-invitation-only/issues"
  },
  "homepage": "https://github.com/vcode-sh/better-auth-invitation-only#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "npx ultracite check",
    "lint:fix": "npx ultracite fix",
    "prepublishOnly": "npm run type-check && npm run test && npm run build"
  },
  "sideEffects": false,
  "peerDependencies": {
    "better-auth": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.10",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.5",
    "better-auth": "^1.4.18",
    "happy-dom": "^16.6.0",
    "lint-staged": "^15.4.3",
    "tsup": "^8.3.6",
    "typescript": "^5.8.0",
    "ultracite": "^4.1.12",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "npx ultracite fix"
  }
}
